        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n!theme plain\nskinparam componentStyle uml2\n\npackage \&quot;Data Sources &amp; Ingestion\&quot; {\n  [EO Satellites\\n(Sentinel, Landsat)] as EO\n  [Health Registries\\n(NICD, DoH)] as Health\n  [Ground Sensors\\n(Water Quality, DWS)] as Ground\n}\n\npackage \&quot;Processing Pipeline\&quot; {\n  [Ingestion &amp; QA\\n(Atmospheric Correction)] as Ingest\n  [Feature Extraction\\n(NDWI, NDVI, SST)] as Features\n  database \&quot;Storage\\n(Cloud DB &amp; Lake)\&quot; as Storage\n}\n\npackage \&quot;Analytics Engine\&quot; {\n  [Spatial-Temporal Fusion\\n(Join by GPS/Date)] as Fusion\n  [Risk Modelling\\n(Pathogen &amp; NCD)] as Risk\n}\n\npackage \&quot;Output Layer\&quot; {\n  [Surveillance Dashboard] as Dash\n  [Alert System\\n(SMS/Email)] as Alerts\n}\n\nEO --&gt; Ingest\nHealth --&gt; Ingest\nGround --&gt; Ingest\nIngest --&gt; Features\nFeatures --&gt; Storage\nStorage --&gt; Fusion\nFusion --&gt; Risk\nRisk --&gt; Dash\nRisk --&gt; Alerts\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="Zb2AefCAak4G7UNasL4U-2">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
